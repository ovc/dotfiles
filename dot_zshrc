    for conf in ~/.zshrc ~/.zlogin ~/.zprofile ~/.p10k.zsh; do
        if [[ "$conf" -nt "$conf.zwc" || ! -f "$conf.zwc" ]]; then
            zcompile "$conf"
        fi
    done
) &!
 
